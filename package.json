{
  "name": "openstudio-daw",
  "main": "electron/main.mjs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "refresh:packs": "node scripts/generate-packs-manifest.mjs",
    "predev": "npm run refresh:packs",
    "prebuild": "npm run refresh:packs",
    "dev": "vite",
    "build": "vite build",
    "desktop:dev": "node scripts/electron-dev.mjs",
    "electron:icon": "node scripts/generate-electron-icon.mjs",
    "desktop:pack": "npm run build && npm run electron:icon && electron-builder --win --dir",
    "desktop:start": "npm run desktop:pack && .\\release\\win-unpacked\\OpenStudio.exe",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@reduxjs/toolkit": "^2.11.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "react-rnd": "^10.5.3",
    "soundfont-player": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^2.1.8",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.openstudio.app",
    "productName": "OpenStudio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "icon": "build/icon.ico"
    }
  }
}
